# ===== Salin file ini jadi ".env" lalu isi nilainya =====
# cp .env.example .env   (atau copy manual di Windows)

# --- Gemini API ---
# Ambil API key gratis di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Model Gemini yang dipakai (default cukup)
GEMINI_MODEL=gemini-2.5-flash

# --- Google Calendar ---
# ID kalender "Keluarga". Diisi OTOMATIS setelah jalanin: npm run auth:google
# Biarkan kosong dulu sebelum step auth Google.
CALENDAR_ID=

# --- WhatsApp / Grup ---
# JID grup keluarga tujuan (format: xxxxxxxxxxx@g.us).
# Diisi setelah bot konek & kita lihat log grup mana. Biarkan kosong dulu.
FAMILY_GROUP_JID=

# --- Scheduler ---
# Jam kirim reminder + info harian (format 24 jam, WIB). Contoh 07:00.
DAILY_JOB_HOUR=7
DAILY_JOB_MINUTE=0
# Timezone (jangan diubah kecuali paham)
TIMEZONE=Asia/Jakarta

# --- Konteks lokal untuk fitur info harian ---
LOCATION_NAME=Harapan Indah, Bekasi

# --- Google Maps / Places API (OPSIONAL) ---
# Key Cloud biasa (AIzaSy...) buat thumbnail kuliner yang ada nama+foto tempat.
# Aktifin "Places API (New)" di Google Cloud, bikin API key, taruh di sini.
# Kalau kosong, link kuliner tetap muncul tapi preview-nya generik.
MAPS_API_KEY=
